# - Application -
APP_VERSION=v1
DOMAIN=localhost
SERVER_PORT=:8080
HTTPS=false

# - Database -
DB_PATH=./data/forma.db
GEOIP_DB_PATH=./data/GeoLite2-Country.mmdb

# - Security & Auth -
BCRYPT_COST=12
JWT_TTL=4380
JWT_SECRET_KEY=change_me_to_a_very_long_random_string_in_production

# - Forma Features Settings -
# Symbols for Auth
PASSWORD_MIN=4
PASSWORD_MAX=128

USERNAME_MIN=4
USERNAME_MAX=24

# Public Poll ID Length, like example.com/p/D7ks81mt
SHORT_ID_LENGTH=8
